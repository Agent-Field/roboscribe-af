# --- Provider key (OpenRouter — open-source models only) ---
OPENROUTER_API_KEY=sk-or-v1-...

# --- Vision model selection (LiteLLM-style strings) ---
# Default: Qwen3-VL-32B (Apache 2.0)
AI_MODEL=openrouter/qwen/qwen3-vl-32b-instruct

# Alternatives — all open-source via OpenRouter:
# AI_MODEL=openrouter/qwen/qwen3-vl-8b-instruct                      # smaller, faster, cheaper
# AI_MODEL=openrouter/qwen/qwen3-vl-235b-a22b-instruct               # flagship Qwen, highest accuracy
# AI_MODEL=openrouter/nvidia/nemotron-nano-12b-v2-vl:free            # NVIDIA Nemotron Nano VL (free, requires OpenRouter privacy toggle for NVIDIA model family)
# AI_MODEL=openrouter/meta-llama/llama-3.2-90b-vision-instruct       # Meta Llama Vision 90B

# --- Smart routing model pair (for smart_frame_validator) ---
SCOUT_MODEL=openrouter/qwen/qwen3-vl-8b-instruct
EXPERT_MODEL=openrouter/qwen/qwen3-vl-235b-a22b-instruct

# --- Text embedder (for scene_embedding, 1024-dim cosine_similarity TQL) ---
EMBED_MODEL=BAAI/bge-large-en-v1.5

# --- Task adapter (which dataset shape to run on) ---
AF_TASK=pusht
# AF_TASK=aloha_transfer

# --- Deep Lake substrate location (persisted via Docker volume) ---
DL_DATASET_PATH=/data/roboscribe_deeplake/roboscribe_pusht

# --- Network ---
AGENT_NODE_ID=roboscribe-af
AGENT_NODE_PORT=8001
AGENTFIELD_HTTP_PORT=8080
